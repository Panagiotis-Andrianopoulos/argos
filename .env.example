# ============================================================
# ARGOS — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in the values.
# The .env file is not committed to git (see .gitignore).
# ============================================================

# --- Application ---
# Environment: dev, staging, production
ARGOS_ENV=dev
# Log level: DEBUG, INFO, WARNING, ERROR
ARGOS_LOG_LEVEL=INFO

# --- Postgres Database ---
# Local development values (for Docker Compose)
ARGOS_DB_HOST=localhost
ARGOS_DB_PORT=5432
ARGOS_DB_NAME=argos
ARGOS_DB_USER=argos
ARGOS_DB_PASSWORD=change_me_in_real_env

# --- Object Storage (MinIO local / Cloudflare R2 production) ---
ARGOS_S3_ENDPOINT_URL=http://localhost:9000
ARGOS_S3_ACCESS_KEY=minioadmin
ARGOS_S3_SECRET_KEY=minioadmin
ARGOS_S3_BUCKET=argos-data
ARGOS_S3_REGION=auto

# --- MLflow ---
ARGOS_MLFLOW_TRACKING_URI=http://localhost:5000

# --- Scraping ---
# Delay (seconds) between requests — respectful scraping
ARGOS_SCRAPER_DELAY_SECONDS=5
# User agent for the scrapers
ARGOS_SCRAPER_USER_AGENT=ARGOS-Bot/0.1 (Research project)
# Max concurrent requests
ARGOS_SCRAPER_CONCURRENCY=2
