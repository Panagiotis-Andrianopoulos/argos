# ============================================================
# Default behavior: automatic text detection with LF storage
# ============================================================
* text=auto eol=lf

# ============================================================
# Source code — always LF
# ============================================================
*.py       text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.toml     text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.sh       text eol=lf

# Config files
.gitignore text eol=lf
.gitattributes text eol=lf
.env.example text eol=lf

# Dockerfile και docker-compose
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# ============================================================
# Windows-specific files — CRLF
# ============================================================
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# ============================================================
# Binary files — non text
# ============================================================
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.pkl      binary
*.parquet  binary
*.db       binary
*.sqlite   binary
*.sqlite3  binary
